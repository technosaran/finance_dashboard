{
  "name": "findashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ci": "npm run build && playwright test",
    "perf:lighthouse": "node scripts/run-lighthouse.mjs",
    "perf:lighthouse:ci": "npm run build && start-server-and-test \"npm run start -- --port 3100\" http://localhost:3100 \"node scripts/run-lighthouse.mjs http://localhost:3100\"",
    "qa:all": "npm run test && npm run test:e2e:ci && npm run perf:lighthouse:ci",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "@vercel/kv": "^3.0.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.0",
    "react": "19.2.3",
    "react-calendar": "^6.0.0",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "start-server-and-test": "^3.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
